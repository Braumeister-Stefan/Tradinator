# Tradinator broker credentials
# Copy this file to secrets/.env and fill in your values.
# NEVER commit the real .env file.

# --- IG Trading (default broker) ---
IG_USERNAME=your_username_here
IG_PASSWORD=your_password_here
IG_API_KEY=your_api_key_here
IG_ACC_TYPE=DEMO
IG_ACC_NUMBER=

# --- IBKR (placeholder — not yet implemented) ---
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# IBKR_CLIENT_ID=1

# --- Dashboard delivery (optional) ---
# DELIVER_MODE=localhost          # localhost | file_only | ftp | netlify
# DASHBOARD_DATA_URL=https://wilmars.one/dashboard_data.json   # Netlify: root path
# DASHBOARD_DATA_URL=https://wilmars.one/tradinator/dashboard_data.json  # FTP: sub-directory

# --- GoDaddy FTP (required when DELIVER_MODE=ftp) ---
# FTP_HOST=ftp.yourdomain.com
# FTP_USER=your_ftp_username
# FTP_PASSWORD=your_ftp_password
# FTP_REMOTE_DIR=/public_html                    # receives performance_dashboard.html
# FTP_JSON_REMOTE_DIR=/public_html/tradinator    # receives dashboard_data.json (polled by the website JS)

# --- Netlify (required when DELIVER_MODE=netlify) ---
# NETLIFY_TOKEN=your_netlify_personal_access_token
# NETLIFY_SITE_ID=your_netlify_site_id
